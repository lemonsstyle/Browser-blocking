{
  "manifest_version": 3,
  "name": "Result Keyword Filter",
  "version": "0.1.0",
  "description": "Hide search results whose titles contain blocked keywords.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Keyword Filter",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
